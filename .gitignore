# macOS
.DS_Store

# 环境变量（含 API 密钥，不得提交）
.env

# SQLite 数据库文件（运行时生成）
backend/data/
*.db
*.db-wal
*.db-shm

# Drizzle 生成的迁移文件（项目使用 db:push，不使用迁移文件）
backend/drizzle/

# 运行日志
logs/

# 依赖
node_modules/

# 构建产物
dist/
build/
.vite/
*.tsbuildinfo

# 测试产生的临时文件
km_service/skills/.sandbox/
km_service/skills/biz-skills/test-skill-*/

# 测试产物
**/test-results/
**/playwright-report/

# KM E2E 测试的 npm lock（npx playwright 产生的副作用）
km_service/frontend/tests/e2e/package-lock.json

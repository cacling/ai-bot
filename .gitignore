# macOS
.DS_Store

# 环境变量（含 API 密钥，不得提交）
.env

# SQLite 数据库文件（运行时生成）
backend/data/
*.db
*.db-wal
*.db-shm

# Drizzle 生成的迁移文件（项目使用 db:push，不使用迁移文件）
backend/drizzle/

# 运行日志
logs/

# 依赖
node_modules/

# 构建产物
dist/
build/
.vite/

# 测试产生的临时文件
backend/skills/.sandbox/
backend/skills/biz-skills/test-skill-*/

# 测试产物
**/test-results/
**/playwright-report/

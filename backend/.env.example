# SiliconFlow LLM
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-siliconflow-api-key
#SILICONFLOW_CHAT_MODEL=stepfun-ai/Step-3.5-Flash
#SILICONFLOW_CHAT_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
SILICONFLOW_CHAT_MODEL=Qwen/Qwen2.5-32B-Instruct

# Query Normalizer LLM（用户输入标准化：口语改写、时间归一化、术语映射、槽位抽取、歧义标记）
# 仅在规则引擎低置信时触发，要求低延迟，默认 Step-3.5-Flash
QUERY_NORMALIZER_MODEL=stepfun-ai/Step-3.5-Flash

# GLM-Realtime（语音模型）
ZHIPU_API_KEY=your-zhipu-api-key
GLM_REALTIME_URL=wss://open.bigmodel.cn/api/paas/v4/realtime
GLM_REALTIME_MODEL=glm-realtime-flash

# Skill Creator LLM（需求分析 / SKILL.md 生成，Qwen3 Max）
SKILL_CREATOR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SKILL_CREATOR_API_KEY=your-qwen-api-key
SKILL_CREATOR_MODEL=qwen3-max
SKILL_CREATOR_VISION_MODEL=qwen-vl-max-latest

# Database（SQLite 文件路径，相对 backend/ 目录；有默认值可不填）
SQLITE_PATH=../data/telecom.db

# MCP Servers（5 个独立服务，URL 写入 DB mcpServers 表，由 seed.ts 初始化）
# TELECOM_MCP_URL 仅作为 DB 无记录时的 fallback
TELECOM_MCP_URL=http://127.0.0.1:18003/mcp
# 用户信息服务（查询用户、账单、套餐、账单异常分析）  → :18003/mcp
# 业务办理服务（退订、开发票）                        → :18004/mcp
# 故障诊断服务（网络诊断、App 诊断）                  → :18005/mcp
# 外呼服务（通话记录、短信、回访、营销记录）           → :18006/mcp
# 账户操作服务（停机保号、充值、密码重置、实名认证）    → :18007/mcp

# Skills directory (relative to backend/ working directory)
SKILLS_DIR=./skills

# GLM-Realtime VAD（语音活动检测）
# VAD_THRESHOLD: 0.0-1.0，越高越不灵敏（过滤噪音），太高会漏掉轻声说话（默认 0.8）
# VAD_SILENCE_MS: 静默确认时长（ms），说完后等多久才算一轮结束（默认 2000）
# VAD_INTERRUPT: 是否允许用户打断机器人说话（默认 false）
#VAD_THRESHOLD=0.8
#VAD_SILENCE_MS=2000
#VAD_INTERRUPT=false

# 语音通道文字 LLM 加工（工具结果经文字模型生成口语化回复再喂给 GLM）
#VOICE_PROCESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# Agent Workstation — 初始隐藏的卡片（逗号分隔），收到对应 WS 事件时自动展开
# 可选值: user_detail, outbound_task, emotion, compliance, handoff, reply_hint, diagram
AGENT_HIDDEN_CARDS=handoff,reply_hint,outbound_task

# Server
PORT=18472

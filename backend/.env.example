# Database（SQLite 文件路径，相对 backend/ 目录；有默认值可不填）
SQLITE_PATH=../data/telecom.db

# SiliconFlow LLM
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_CHAT_MODEL=stepfun-ai/Step-3.5-Flash

# Skill Creator LLM（需求分析 / SKILL.md 生成，默认 Qwen3 Max）
SKILL_CREATOR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SKILL_CREATOR_API_KEY=your-qwen-api-key-here
SKILL_CREATOR_MODEL=qwen-max-latest

# MCP Servers
TELECOM_MCP_URL=http://localhost:8003/mcp

# Skills directory (relative to backend/ working directory)
SKILLS_DIR=./skills

# Server
PORT=8000

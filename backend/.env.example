# Database（SQLite 文件路径，相对 backend/ 目录；有默认值可不填）
SQLITE_PATH=./data/telecom.db

# SiliconFlow LLM
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_CHAT_MODEL=stepfun-ai/Step-3.5-Flash

# MCP Servers
TELECOM_MCP_URL=http://localhost:8003/mcp

# Skills directory (relative to backend/ working directory)
SKILLS_DIR=./skills

# Server
PORT=8000

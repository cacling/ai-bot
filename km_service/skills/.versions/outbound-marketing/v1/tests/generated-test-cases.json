      "id": "REQ-001",
      "source": "frontmatter",
      "description": "技能应在营销任务平台下发外呼任务时被触发，主动拨打电话向客户推介套餐升级方案"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "系统应基于任务注入的客户信息（姓名、性别、当前套餐、目标套餐等）个性化开场和推介"
    },
    {
      "id": "REQ-003",
      "source": "workflow",
      "description": "拨号前必须检查 allowed_hours、max_retry 和 DND 名单，任一不合规则延后或终止任务"
    },
    {
      "id": "REQ-004",
      "source": "workflow",
      "description": "呼叫未接通或进入语音信箱时，应记录为 no_answer 并按策略重试"
    },
    {
      "id": "REQ-005",
      "source": "workflow",
      "description": "开场白必须包含自我介绍、录音告知、身份确认（使用已知姓名）和征得客户同意继续"
    },
    {
      "id": "REQ-006",
      "source": "workflow",
      "description": "身份确认失败（非本人接听）时，应记录为 wrong_number 并结束通话"
    },
    {
      "id": "REQ-007",
      "source": "workflow",
      "description": "客户初始意愿为拒绝时，应立即收口，不得进行多轮异议处理"
    },
    {
      "id": "REQ-008",
      "source": "workflow",
      "description": "客户明确要求停止拨打或删除营销名单时，应优先处理 DND 请求并记录 dnd 结果"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "方案介绍应基于目标套餐的核心卖点（≤2个），结合客户当前套餐痛点进行推介"
    },
    {
      "id": "REQ-010",
      "source": "workflow",
      "description": "客户对其他套餐感兴趣时，应切换 target_plan 并重新介绍新套餐"
    },
    {
      "id": "REQ-011",
      "source": "workflow",
      "description": "针对价格、合约、够用等异议，应提供针对性回应，并根据客户二次表态决定后续路径"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "客户同意办理后，必须再次确认意愿，确认后再执行成交并行处理（发短信+记录结果）"
    },
    {
      "id": "REQ-013",
      "source": "workflow",
      "description": "成交场景下，应并行发送套餐详情短信并记录 converted 结果，根据短信发送成功与否引导自助办理"
    },
    {
      "id": "REQ-014",
      "source": "workflow",
      "description": "客户犹豫需考虑时，应确认回访时间，并并行发送短信和记录 callback 结果"
    },
    {
      "id": "REQ-015",
      "source": "workflow",
      "description": "客户要求转人工或出现情绪激烈、投诉意向时，应立即调用 transfer_to_human 转接坐席"
    },
    {
      "id": "REQ-016",
      "source": "tool",
      "description": "所有通话结果（converted/callback/not_interested/no_answer/wrong_number/dnd）必须通过 record_marketing_result 工具准确记录"
    },

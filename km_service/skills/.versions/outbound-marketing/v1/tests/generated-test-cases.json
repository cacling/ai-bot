    {
      "id": "REQ-001",
      "source": "frontmatter",
      "description": "系统应在营销任务平台下发任务时加载外呼营销技能，并使用注入的客户信息和目标套餐进行主动外呼"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "外呼前必须已注入客户姓名、性别、当前套餐、目标套餐、话术模板等上下文数据"
    },
    {
      "id": "REQ-003",
      "source": "workflow",
      "description": "拨打电话前必须检查 allowed_hours、max_retry 和 DND 名单，任一不合规则延后或终止任务"
    },
    {
      "id": "REQ-004",
      "source": "workflow",
      "description": "呼叫未接通、忙线或语音信箱时，应记录为 no_answer 并结束通话"
    },
    {
      "id": "REQ-005",
      "source": "workflow",
      "description": "开场白必须包含自我介绍、录音告知、身份确认（使用已知姓名）和征得客户同意继续介绍"
    },
    {
      "id": "REQ-006",
      "source": "workflow",
      "description": "若接听者非本人，应记录为 wrong_number 并礼貌结束"
    },
    {
      "id": "REQ-007",
      "source": "workflow",
      "description": "客户明确拒绝后不得继续推销，应立即记录为 not_interested 并道谢结束"
    },
    {
      "id": "REQ-008",
      "source": "workflow",
      "description": "客户表示没时间或需要考虑时，应询问回访时间并进入待回访流程"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "方案介绍应基于目标套餐，突出不超过两个核心卖点，并结合客户当前套餐痛点"
    },
    {
      "id": "REQ-010",
      "source": "workflow",
      "description": "客户对其他套餐感兴趣时，应切换 target_plan 并重新介绍新套餐"
    },
    {
      "id": "REQ-011",
      "source": "workflow",
      "description": "针对价格、合约、够用等异议，应按话术手册进行针对性回应"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "客户要求转人工时，应立即调用 transfer_to_human 转接坐席"
    },
    {
      "id": "REQ-013",
      "source": "workflow",
      "description": "客户同意办理后，需再次确认意愿，确认后并行发送套餐短信并记录 converted 结果"
    },
    {
      "id": "REQ-014",
      "source": "workflow",
      "description": "客户要求不再来电或删除营销名单时，应记录为 dnd 并从名单移除"
    },
    {
      "id": "REQ-015",
      "source": "workflow",
      "description": "客户情绪激烈、质疑合法性或有投诉意向时，应立即转接人工"
    },
    {
      "id": "REQ-016",
      "source": "tool",
      "description": "所有通话结果（converted/callback/not_interested/no_answer/wrong_number/dnd）必须通过 record_marketing_result 工具准确记录"
    },
    {
      "id": "REQ-017",
      "source": "tool",
      "description": "成交或待回访场景下，应调用 send_followup_sms 发送 plan_detail 类型短信"
    },
    {
      "id": "REQ-018",
      "source": "compliance",
      "description": "禁止在客户明确拒绝后继续多轮推销，必须一次拒绝即收口"
    },

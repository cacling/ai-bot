    {
      "id": "REQ-001",
      "source": "frontmatter",
      "description": "技能应仅处理 App 登录、闪退、安装更新、设备安全与页面技术异常，不处理账单解读、套餐咨询、业务退订等业务问题"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "当用户反映 App 无法打开、闪退、卡顿时，应触发 app_crash 类型的诊断流程"
    },
    {
      "id": "REQ-003",
      "source": "trigger",
      "description": "当用户无法登录（密码错误、OTP 未收到、账号被锁）时，应触发 login_issue 类型的处理流程"
    },
    {
      "id": "REQ-004",
      "source": "trigger",
      "description": "当用户报告 App 内功能异常（如查话费、缴费、办理业务页面报错或无响应）时，应触发 feature_error 类型的排查流程"
    },
    {
      "id": "REQ-005",
      "source": "trigger",
      "description": "当用户无法安装 App 或无法升级至新版本时，应触发 install_update 类型的引导流程"
    },
    {
      "id": "REQ-006",
      "source": "trigger",
      "description": "当 App 提示设备环境异常、安全检测不通过，或账号显示可疑活动、被风控限制时，应触发 security_check 类型的安全诊断"
    },
    {
      "id": "REQ-007",
      "source": "trigger",
      "description": "当用户询问附近营业厅地址、线下网点位置或如何前往营业厅时，应触发 store_locator 类型的位置服务流程"
    },
    {
      "id": "REQ-008",
      "source": "workflow",
      "description": "系统应在接收问题后根据用户描述准确分类 issue_type，并进入对应的子流程（app_crash / login_issue / feature_error / install_update / security_check / store_locator）"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "对于 app_crash 问题，应先检查 App 版本，若版本过旧则引导更新；若版本正常则引导清缓存、重启、清存储，并在无效时升级 frontline"
    },
    {
      "id": "REQ-010",
      "source": "workflow",
      "description": "对于 login_issue 问题，应根据具体子类型（密码错误、OTP 未达、账号锁定、生物识别失败）分别引导重置密码、OTP 排查、安全诊断或重新录入生物特征"
    },
    {
      "id": "REQ-011",
      "source": "tool",
      "description": "涉及账号安全或设备风险的登录问题，必须调用 diagnose_app 工具获取诊断结果，不得凭空推断"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "对于 feature_error 问题，应先确认具体异常类型（页面/按钮/支付/账号状态），再针对性排查网络、版本、缓存或账户状态"
    },
    {
      "id": "REQ-013",
      "source": "tool",
      "description": "当 feature_error 涉及账号状态异常提示时，必须先调用 query_subscriber 工具核实用户真实状态，再决定是否引导缴费或继续排查"
    },
    {
      "id": "REQ-014",
      "source": "workflow",
      "description": "对于 install_update 问题，应引导用户检查系统版本、存储空间和网络，并在自助无效时提供官方下载渠道"
    },
    {
      "id": "REQ-015",
      "source": "workflow",
      "description": "对于 security_check 问题，必须调用 diagnose_app 工具执行安全诊断，并根据风险等级决定是告知硬性限制、引导修复还是升级 security_team"
    },
    {
      "id": "REQ-016",
      "source": "workflow",
      "description": "当 diagnose_app 返回设备存在 Root/模拟器等硬性限制时，若用户否认，应升级 frontline 人工核查设备状态"
    },
    {
      "id": "REQ-017",
      "source": "workflow",
      "description": "对于 store_locator 问题，应先获取用户位置，再调用 maps_around_search 搜索附近营业厅，并可按需调用 maps_direction_walking 提供步行导航"
    },
    {
      "id": "REQ-018",
      "source": "workflow",
      "description": "所有问题处理流程中，若用户表示问题已解决，应礼貌结束对话；若未解决，应统一升级 frontline"
    },
    {
      "id": "REQ-019",
      "source": "workflow",
      "description": "用户在任何阶段要求转人工时，应立即转接人工客服并结束流程"
    },
    {
      "id": "REQ-020",
      "source": "boundary",
      "description": "当用户提到'App 里 XXX 不行'时，应先澄清是 App 技术故障还是业务操作问题，仅在确认为技术故障时才进入本技能流程"
    }
  ],

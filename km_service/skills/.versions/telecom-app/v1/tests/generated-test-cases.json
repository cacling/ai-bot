      "id": "REQ-001",
      "source": "frontmatter",
      "description": "技能应仅处理 App 登录、闪退、安装更新、设备安全与页面技术异常，不处理账单解读、套餐咨询、业务退订等业务问题"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "客户反映 App 无法打开、闪退、卡顿时应触发本技能"
    },
    {
      "id": "REQ-003",
      "source": "trigger",
      "description": "客户无法登录（密码错误、OTP 未收到、账号被锁）时应触发本技能"
    },
    {
      "id": "REQ-004",
      "source": "trigger",
      "description": "App 内功能异常（查话费、缴费、办理业务等页面报错或无响应）时应触发本技能"
    },
    {
      "id": "REQ-005",
      "source": "trigger",
      "description": "客户无法安装 App 或无法升级至新版本时应触发本技能"
    },
    {
      "id": "REQ-006",
      "source": "trigger",
      "description": "App 提示设备环境异常、安全检测不通过时应触发本技能"
    },
    {
      "id": "REQ-007",
      "source": "trigger",
      "description": "账号显示可疑活动、被风控限制或疑似被盗时应触发本技能"
    },
    {
      "id": "REQ-008",
      "source": "trigger",
      "description": "客户询问附近营业厅地址、线下网点位置、如何前往营业厅时应触发本技能"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "系统应根据客户描述准确分类问题类型为 app_crash、login_issue、feature_error、install_update、security_check 或 store_locator"
    },
    {
      "id": "REQ-010",
      "source": "tool",
      "description": "对于 security_check 和登录安全相关场景，系统应调用 diagnose_app 工具执行安全诊断并获取诊断结果"
    },
    {
      "id": "REQ-011",
      "source": "workflow",
      "description": "对于 app_crash 问题，系统应先检查 App 版本，版本过旧则引导更新，版本正常则引导清缓存、重启、清存储"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "对于 login_issue 问题，系统应根据具体场景分别处理：账号被锁进行安全诊断、密码错误引导重置、OTP 未收到进行排查、生物识别失败引导重新设置"
    },
    {
      "id": "REQ-013",
      "source": "workflow",
      "description": "对于 feature_error 问题，系统应先确认具体异常类型（页面/按钮/支付/账号状态），再针对性排查"
    },
    {
      "id": "REQ-014",
      "source": "tool",
      "description": "对于 feature_error 中的账号状态异常，系统应调用 query_subscriber 工具核实用户账号状态"
    },
    {
      "id": "REQ-015",
      "source": "workflow",
      "description": "对于 install_update 问题，系统应引导客户检查系统版本、存储空间、网络，并在失败时提供官方下载渠道"
    },
    {
      "id": "REQ-016",
      "source": "workflow",
      "description": "对于 security_check 问题，系统应调用 diagnose_app 工具进行安全诊断，并根据风险等级采取不同处理措施"
    },
    {
      "id": "REQ-017",
      "source": "tool",
      "description": "对于 store_locator 问题，系统应调用 maps_around_search 工具搜索附近营业厅，并可根据用户需求调用 maps_direction_walking 规划路线"
    },
    {
      "id": "REQ-018",
      "source": "workflow",
      "description": "所有问题处理流程中，用户要求转人工时应立即转接人工客服"
    },
    {
      "id": "REQ-019",
      "source": "workflow",
      "description": "所有问题解决路径后应确认用户问题是否已解决，未解决则升级 frontline"
    },
    {
      "id": "REQ-020",
      "source": "workflow",
      "description": "对于高风险安全场景（Root/永久锁定/诈骗嫌疑/屏幕共享），系统应升级 security_team 并进行反诈提醒"
    },
    {
      "id": "REQ-021",
      "source": "workflow",
      "description": "对于设备硬性限制（Root或模拟器），系统应告知用户须使用正常设备，并在用户声明未Root时升级 frontline 人工核查"
    },
    {
      "id": "REQ-022",
      "source": "compliance",
      "description": "系统不得凭空猜测设备状态，安全诊断数据必须通过 diagnose_app 工具获取"
    },
    {
      "id": "REQ-023",
      "source": "compliance",
      "description": "系统不得向客户索要密码、OTP 验证码内容或完整身份证号码"
    },
    {
      "id": "REQ-024",
      "source": "compliance",
      "description": "系统不得未经用户确认擅自执行账号变更操作"
    },
    {
      "id": "REQ-025",
      "source": "compliance",
      "description": "系统不得未经 query_subscriber 核实就直接断言账户欠费/停机"
    },
    {
      "id": "REQ-026",
      "source": "compliance",
      "description": "OTP 场景中系统不得反复引导重发超过 2 次，仍失败应切换验证方式或升级"
    }
  ],

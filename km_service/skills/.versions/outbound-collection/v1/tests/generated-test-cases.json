  "requirements": [
    {
      "id": "REQ-001",
      "source": "frontmatter",
      "description": "技能应在催收任务平台下发任务时被触发，主动外呼客户进行逾期账款提醒"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "系统应基于任务注入的客户信息（姓名、性别、欠款金额、逾期天数等）直接开展催收对话，不得询问客户基础身份或欠款信息"
    },
    {
      "id": "REQ-003",
      "source": "workflow",
      "description": "外呼前必须检查当前时间是否在 allowed_hours 允许拨打时段内，且未超过 max_retry 次数"
    },
    {
      "id": "REQ-004",
      "source": "workflow",
      "description": "通话开始时必须告知客户本通话可能被录音，并使用已知姓名确认客户身份"
    },
    {
      "id": "REQ-005",
      "source": "workflow",
      "description": "仅当客户确认是本人后，才可告知欠款详情并询问还款意向"
    },
    {
      "id": "REQ-006",
      "source": "tool",
      "description": "系统应根据客户回复准确分类还款意向（ptp/callback/dispute/refusal/transfer/vulnerable 等）并执行对应处理流程"
    },
    {
      "id": "REQ-007",
      "source": "workflow",
      "description": "承诺还款（ptp）必须同时满足两个条件：客户明确说出还款日期 + 明确口头承诺，方可记录为 ptp"
    },
    {
      "id": "REQ-008",
      "source": "workflow",
      "description": "若客户承诺的还款日期超出 max_ptp_days 限制，应引导客户协商更近的日期；若无法达成一致，应转人工"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "对特殊困难客户（如严重疾病、丧失劳动能力、机主已故、情绪极度脆弱），应立即停止施压并转人工"
    },
    {
      "id": "REQ-010",
      "source": "workflow",
      "description": "客户要求不再来电（DND）时，必须记录 dnd 结果并从后续外呼名单中移除"
    },
    {
      "id": "REQ-011",
      "source": "workflow",
      "description": "模糊意愿（如'最近''回头''晚点看看'）不得记录为 ptp，应追问具体日期或转为预约回呼"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "每通电话最多只能提醒一次逾期后果，禁止在客户明确拒绝后反复施压"
    },
    {
      "id": "REQ-013",
      "source": "workflow",
      "description": "任意节点若客户情绪激烈失控、威胁自伤或诉讼，应立即转人工"
    },
    {
      "id": "REQ-014",
      "source": "workflow",
      "description": "通话结束前必须调用 record_call_result 工具记录最终结果"
    },
    {
      "id": "REQ-015",
      "source": "workflow",
      "description": "非本人接听时，应记录 non_owner 并请对方转告机主，不得继续催收"
    },
    {
      "id": "REQ-016",
      "source": "workflow",
      "description": "PTP 成功确认后，应并行发送还款链接短信并记录承诺结果"
    },
    {
      "id": "REQ-017",
      "source": "workflow",
      "description": "预约回呼场景下，应确认客户期望的回呼时间和号码，并创建回访任务"
    },
    {
      "id": "REQ-018",
      "source": "compliance",
      "description": "严禁使用威胁、恐吓、侮辱性语言，或编造不实欠款信息"
    }
  ],

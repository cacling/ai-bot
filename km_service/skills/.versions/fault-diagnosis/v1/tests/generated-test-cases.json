  "requirements": [
    {
      "id": "REQ-001",
      "source": "frontmatter",
      "description": "技能应在用户表达网络故障意图（如无信号、网速骤降、通话中断、无法上网）时被加载"
    },
    {
      "id": "REQ-002",
      "source": "trigger",
      "description": "用户反映最近突然变慢的网速问题应触发本技能，而非套餐查询"
    },
    {
      "id": "REQ-003",
      "source": "trigger",
      "description": "当用户描述'月底限速'或'流量用尽'等长期问题时，不应进入本技能，应转至套餐查询"
    },
    {
      "id": "REQ-004",
      "source": "workflow",
      "description": "系统在接收用户故障描述后，应立即调用 diagnose_network 工具进行预诊断，不得先反复追问问题细节"
    },
    {
      "id": "REQ-005",
      "source": "tool",
      "description": "diagnose_network 工具必须根据用户描述准确映射 issue_type（no_signal / slow_data / call_drop / no_network）"
    },
    {
      "id": "REQ-006",
      "source": "workflow",
      "description": "诊断结果中若账号状态为欠费停机，应进入【账号停机】状态并告知充值方式及恢复时间"
    },
    {
      "id": "REQ-007",
      "source": "workflow",
      "description": "诊断结果中若流量已耗尽，应进入【流量耗尽】状态并推荐加油包或升级套餐"
    },
    {
      "id": "REQ-008",
      "source": "workflow",
      "description": "诊断结果中若存在 APN 配置异常，应引导用户重置 APN 并等待操作反馈"
    },
    {
      "id": "REQ-009",
      "source": "workflow",
      "description": "诊断结果中若基站信号异常，应说明需人工跟进，建议转人工提交工单，不得声称已提交或提供工单号"
    },
    {
      "id": "REQ-010",
      "source": "workflow",
      "description": "诊断结果全部正常时，应进入【用户自查】状态，并逐步引导用户执行单一操作（如关飞行模式、插拔SIM卡、重启手机），每步确认结果"
    },
    {
      "id": "REQ-011",
      "source": "workflow",
      "description": "在【确认恢复】状态，系统应仅询问'问题是否解决'，不得调用工具或给出新建议"
    },
    {
      "id": "REQ-012",
      "source": "workflow",
      "description": "用户确认问题未解决或自查无效后，应进入【升级处理】状态，建议转人工或前往营业厅"
    },
    {
      "id": "REQ-013",
      "source": "workflow",
      "description": "diagnose_network 工具调用失败时，应进入【诊断失败兜底】状态，告知无法获取数据并建议转人工"
    },
    {
      "id": "REQ-014",
      "source": "workflow",
      "description": "任何状态下用户要求转人工，应立即进入【转接人工】状态，尊重用户意愿"
    },
    {
      "id": "REQ-015",
      "source": "compliance",
      "description": "系统不得在无 diagnose_network 诊断数据的情况下断言故障原因或给出结论性建议"
    },
    {
      "id": "REQ-016",
      "source": "compliance",
      "description": "每轮对话只能执行一个操作步骤，不得合并多个引导动作到同一轮回复"
    },
    {
      "id": "REQ-017",
      "source": "workflow",
      "description": "网络拥塞（高峰期）场景下，应说明原因并建议等待或切换 Wi-Fi，随后进入【确认恢复】"
    },
    {
      "id": "REQ-018",
      "source": "boundary",
      "description": "当用户模糊描述'网速慢'时，系统应先澄清是'最近突然变慢'还是'月底限速'，再决定是否进入本技能"
    }

{
  "name": "ai-bot-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "mcp_servers",
    "mock_apis",
    "work_order_service",
    "work_order_service/frontend",
    "km_service",
    "km_service/frontend",
    "cdp_service",
    "outbound_service",
    "interaction_platform",
    "channel_host",
    "wfm_service",
    "wfm_service/frontend",
    "temporal_orchestrator",
    "ontology_service",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:mcp": "npm --workspace @ai-bot/mcp-servers run dev",
    "test:mcp": "npm --workspace @ai-bot/mcp-servers run test",
    "dev:km": "npm --workspace @ai-bot/km-service run dev",
    "dev:km-frontend": "npm --workspace @ai-bot/km-frontend run dev",
    "check:shared-db": "npm --workspace @ai-bot/shared-db run check",
    "check:mcp": "npm --workspace @ai-bot/mcp-servers run check",
    "check:km": "npm --workspace @ai-bot/km-service run check",
    "dev:cdp": "npm --workspace @ai-bot/cdp-service run dev",
    "check:cdp": "npm --workspace @ai-bot/cdp-service run check",
    "dev:ontology": "npm --workspace @ai-bot/ontology-service run dev",
    "check:ontology": "npm --workspace @ai-bot/ontology-service run check"
  }
}

{
  "name": "telecom-support-testcase",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml -c evals/config-multi-turn.yaml -c evals/config-sop-guard.yaml -c evals/config-sandbox.yaml",
    "eval:single": "promptfoo eval -c evals/promptfooconfig.yaml",
    "eval:multi-turn": "promptfoo eval -c evals/config-multi-turn.yaml",
    "eval:sop-guard": "promptfoo eval -c evals/config-sop-guard.yaml",
    "eval:sandbox": "promptfoo eval -c evals/config-sandbox.yaml",
    "eval:no-cache": "promptfoo eval -c evals/promptfooconfig.yaml --no-cache",
    "eval:ci": "promptfoo eval -c evals/promptfooconfig.yaml -c evals/config-multi-turn.yaml -c evals/config-sop-guard.yaml --no-cache -o evals/ci-results.json",
    "eval:view": "promptfoo view"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "promptfoo": "^0.121.3"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  }
}
